--- string, number, dates
use world;
select name, continent, concat(continent,'have',name,'country')from
country;
select name, continent, concat_ws(' ', continent,'have',name,'country')from
country;
select name, upper(name) from country;
select name, upper(name), substr(name,2)from country;-- extract string char 

select name, upper(name), substr(name,2) , substr(name,2,4)from country;
select name, upper(name), substr(name,2) , substr(name,2,4) , substr(name,1,4)
from country where name='colombia';
select name, substr(name,-4) from country
where name='colombia';-- negative means right (backside ) side se 4 
select name, upper(name), substr(name,-4,2) from country
where name= 'colombia';
-- length ( bite use ) and char_length (kitne char h )
select length('77'),char_length('77');
-- replace the char 
select name, replace(name,'a','@')from country;
-- trim work space ko remove krne  from staring and ending 
SELECT TRIM('      he  llo    ');
-- lpad left side char add krne  and rpad
select name,rpad(name,6,'@')from country;
select name,lpad(name,6,'_')from country;
